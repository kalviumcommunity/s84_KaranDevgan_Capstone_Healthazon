# Backend - required
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/healthazon?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password

# Optional: server port (Cloud Run sets PORT automatically)
# PORT=8080

# Frontend / Vite - point to the API base URL (production should be same service origin)
# Example for local dev: VITE_RENDER_API=http://localhost:5000/api
# In production, if serving frontend from same server, use relative path: /api
VITE_RENDER_API=/api
FRONTEND_URL=https://your-production-domain.example.com

# Notes:
# - Keep this file out of version control for real credentials. Use secrets in CI/CD.
# - Update FRONTEND_URL to the public URL of the deployed service for password reset links and emails.